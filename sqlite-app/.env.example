# ── Copy this file to ".env" and fill in the values. ".env" is git-ignored. ──

# Port the web server listens on. (On Render this is set automatically — leave it.)
PORT=3000

# Folder for the SQLite database file. Leave blank to use ./data locally.
# On Render, set this to your persistent disk mount, e.g. /var/data
DATA_DIR=

# Long random string used to sign the login-session cookie. CHANGE THIS.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-string

# Set to "true" only when served over HTTPS (recommended in production).
# When true, the session cookie is only sent over HTTPS.
SECURE_COOKIES=false

# Public base URL of the app (used to build password-reset links in emails).
# e.g. https://tasks.printo.in  or  http://192.168.1.50:3000
APP_URL=http://localhost:3000

# ── First manager login, created only if the users table is empty. ──
# After a fresh install (no migration) you sign in with these, then add the rest
# from the Users tab. Ignored once any user exists.
INITIAL_MANAGER_EMAIL=hamsa.v@printo.in
INITIAL_MANAGER_NAME=Hamsa
INITIAL_MANAGER_PASSWORD=change-me-now

# ── SMTP for notification + password emails (same idea as the old Cloud Function). ──
# Leave blank to run without email: the app still works, but it won't send
# notifications or password links (a manager sets passwords manually instead).
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Time the nightly "send forgotten updates" job runs, as a cron expression,
# and its time zone. Default: 00:00 every day, India time.
NIGHTLY_CRON=0 0 * * *
TZ=Asia/Kolkata
